# URL pubblico (metadata, canonical)
NEXT_PUBLIC_SITE_URL=https://rockislandrimini.it

# Google Analytics 4 (opzionale)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Invio email tramite Resend (https://resend.com). Se manca, le API /api/prenota e /api/convention rispondono 503.
RESEND_API_KEY=
# Esempio: RockIsland <bookings@tuo-dominio.it> (dominio verificato su Resend)
RESEND_FROM=
# Destinatario interno (ricezione lead)
RESEND_TO=


# Per lo sviluppo locale: copia questo file in .env.local (Next.js non carica .env.example).
# Supabase → Settings → API: Project URL e anon public; service_role è il segreto server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opzionale in server: chiave "service_role" (mai nel client). Se manca, si usa l'anon key lato server.
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_PANEL_SLUG=rockisland-control
NEXT_PUBLIC_SITE_URL=http://localhost:3000